# Sandbox0 — managed-agents service
SANDBOX0_BASE_URL=https://agents.sandbox0.ai
SANDBOX0_API_KEY={SANDBOX0_API_KEY}

# LLM credentials — used by the agent for inference (defaults to Anthropic if not set)
LLM_API_KEY={LLM_API_KEY}
# LLM_BASE_URL=https://open.bigmodel.cn/api/anthropic

# Managed agent version to use (reads from managed_agent table; "default" uses is_default=true row)
MANAGED_AGENT_VERSION=default

# FeatBit access token (fallback if not stored per-experiment in DB)
FEATBIT_ACCESS_TOKEN={FEATBIT_ACCESS_TOKEN}

# PostgreSQL — same DB as agent/web
DATABASE_URL={DATABASE_URL}

# URL of the agent/web app (used in bootstrap message for curl calls)
SYNC_API_URL=http://localhost:3002

# Streaming server port
PORT=3100

# CORS origin (default: * — lock down in production)
# CORS_ORIGIN=https://your-web-app.com
