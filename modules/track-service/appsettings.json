{
  "ClickHouse": {
    // Set via env var CLICKHOUSE_CONNECTION_STRING (k8s Secret) — takes precedence.
    // Format: "Host=<ip>;Port=8123;Username=default;Password=<secret>;Protocol=http;Database=default"
    "ConnectionString": "",
    "Database": "default",
    "FlagEvaluationsTable": "flag_evaluations",
    "MetricEventsTable": "metric_events"
  },
  "Ingest": {
    "ChannelCapacity": 100000,
    "BatchSize": 1000,
    "FlushIntervalMs": 5000
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
