# HTTP port the agent's SSE server listens on.
PORT=3031

# Base URL of the web module's memory API (used by scripts/memory-*.ts).
MEMORY_API_BASE=http://localhost:3000

# Fallback session identity. Normal requests should pass projectKey / userId
# in the POST /query body instead of relying on these.
FEATBIT_PROJECT_KEY=
FEATBIT_USER_ID=

# ── Authentication & model — via ~/.codex/config.toml ─────────────────────────
#
# The Codex binary reads model and provider config from config.toml, NOT from
# environment variables. Create the file before running this module.
#
# CODEX_HOME lets you put the config.toml somewhere other than ~/.codex.
# Set it to point to a project-local directory so each deployment can have
# its own settings without touching the user's home directory.
CODEX_HOME=./codex-config
#
# Option A — Standard OpenAI
#   codex-config/config.toml:
#     model = "o4-mini"
#     model_provider = "openai"
#
# Option B — Azure AI Foundry
#   codex-config/config.toml:
#     model = "<your-deployment-name>"
#     model_provider = "azure"
#     [model_providers.azure]
#     name = "Azure AI Foundry"
#     base_url = "https://<resource>.openai.azure.com/openai/v1"
#     env_key = "AZURE_OPENAI_API_KEY"
#     wire_api = "responses"
#
# Note: /openai/v1 already encodes the API version — no OPENAI_API_VERSION needed.

# For Option A: set this.
OPENAI_API_KEY=

# For Option B: set this instead.
# AZURE_OPENAI_API_KEY=
