{
  "name": "project-agent",
  "version": "0.1.0",
  "description": "Project-level FeatBit agent. Runs user onboarding, captures product context, and maintains shared project memory. Built on the OpenAI Codex SDK; exposes an SSE HTTP interface.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "prepare-skills": "tsx scripts/prepare-skills.ts",
    "dev": "npm run prepare-skills && tsx watch src/server.ts",
    "build": "npm run prepare-skills && tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@openai/codex-sdk": "^0.121.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
