generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Activity {
  id           String     @id @default(uuid())
  type         String
  title        String
  detail       String?
  createdAt    DateTime   @default(now()) @map("created_at")
  experimentId String     @map("experiment_id")
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@map("activity")
}

model Experiment {
  id                 String          @id @default(uuid())
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  hypothesis         String?
  accessToken        String?         @map("access_token")
  change             String?
  constraints        String?
  description        String?
  envSecret          String?         @map("env_secret")
  flagKey            String?         @map("flag_key")
  flagServerUrl      String?         @map("flag_server_url")
  goal               String?
  guardrails         String?
  intent             String?
  lastAction         String?         @map("last_action")
  lastLearning       String?         @map("last_learning")
  name               String
  openQuestions      String?         @map("open_questions")
  primaryMetric      String?         @map("primary_metric")
  sandboxId          String?         @map("sandbox_id")
  sandboxStatus      String?         @default("idle") @map("sandbox_status")
  stage              String          @default("hypothesis")
  variants           String?
  featbitProjectKey  String?         @map("featbit_project_key")
  featbitEnvId       String?         @map("featbit_env_id")
  conflictAnalysis   String?         @map("conflict_analysis")
  entryMode          String?         @map("entry_mode")
  activities         Activity[]
  experimentRuns     ExperimentRun[]
  messages           Message[]

  @@map("experiment")
}

model ExperimentRun {
  id                    String     @id @default(uuid())
  experimentId          String     @map("experiment_id")
  slug                  String
  status                String     @default("draft")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")
  hypothesis            String?
  method                String?
  methodReason          String?    @map("method_reason")
  primaryMetricEvent    String?    @map("primary_metric_event")
  metricDescription     String?    @map("metric_description")
  guardrailEvents       String?    @map("guardrail_events")
  guardrailDescriptions String?    @map("guardrail_descriptions")
  controlVariant        String?    @map("control_variant")
  treatmentVariant      String?    @map("treatment_variant")
  trafficAllocation     String?    @map("traffic_allocation")
  minimumSample         Int?       @map("minimum_sample")
  observationStart      DateTime?  @map("observation_start")
  observationEnd        DateTime?  @map("observation_end")
  priorProper           Boolean    @default(false) @map("prior_proper")
  priorMean             Float?     @map("prior_mean")
  priorStddev           Float?     @map("prior_stddev")
  inputData             String?    @map("input_data")
  analysisResult        String?    @map("analysis_result")
  decision              String?
  decisionSummary       String?    @map("decision_summary")
  decisionReason        String?    @map("decision_reason")
  whatChanged           String?    @map("what_changed")
  whatHappened          String?    @map("what_happened")
  confirmedOrRefuted    String?    @map("confirmed_or_refuted")
  whyItHappened         String?    @map("why_it_happened")
  nextHypothesis        String?    @map("next_hypothesis")
  runId                 String?    @map("run_id")
  primaryMetricAgg      String?    @default("once") @map("primary_metric_agg")
  primaryMetricType     String?    @default("binary") @map("primary_metric_type")
  trafficPercent        Float?     @default(100) @map("traffic_percent")
  layerId               String?    @map("layer_id")
  audienceFilters       String?    @map("audience_filters")
  trafficOffset         Int?       @default(0) @map("traffic_offset")
  // Data source for metric stats. Branches the analyse route between
  // FeatBit-managed track-service and a Customer Managed Data Endpoint.
  // Values: "featbit-managed" | "customer-single" | "customer-per-metric" | "manual" | "external-text"
  dataSourceMode         String?    @default("featbit-managed") @map("data_source_mode")
  // JSON-encoded endpoint routing. Shape varies by dataSourceMode:
  //   customer-single:     { "providerId": "...", "path": "/...", "staticParams": {...} }
  //   customer-per-metric: { "<metric_event>": { "providerId": "...", "path": "/...", "staticParams": {...} }, ... }
  customerEndpointConfig String?    @map("customer_endpoint_config")
  experiment            Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@unique([experimentId, slug])
  @@map("experiment_run")
}

model Message {
  id           String     @id @default(uuid())
  role         String
  content      String
  metadata     String?
  createdAt    DateTime   @default(now()) @map("created_at")
  experimentId String     @map("experiment_id")
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@map("message")
}

model ProjectMemory {
  id                String   @id @default(uuid())
  featbitProjectKey String   @map("featbit_project_key")
  key               String
  type              String
  content           String
  sourceAgent       String?  @map("source_agent")
  createdByUserId   String?  @map("created_by_user_id")
  editable          Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([featbitProjectKey, key])
  @@index([featbitProjectKey, type])
  @@map("project_memory")
}

model ProjectAgentSession {
  id            String   @id @default(uuid())
  projectKey    String   @map("project_key")
  userId        String   @map("user_id")
  codexThreadId String?  @map("codex_thread_id")
  messages      String   @default("[]")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([projectKey, userId])
  @@map("project_agent_session")
}

model ManagedAgent {
  version       String   @id
  agentId       String   @map("agent_id")
  environmentId String   @map("environment_id")
  isDefault     Boolean  @default(false) @map("is_default")
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("managed_agent")
}

model Vault {
  name      String   @id
  vaultId   String   @map("vault_id")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("vault")
}

// Customer Managed Data Endpoint provider — see docs/customer-managed-data-endpoints-v1.md.
// Project-scoped (matches Experiment.featbitProjectKey). Holds transport + auth only;
// per-experiment endpoint path/params live on ExperimentRun.customerEndpointConfig.
model CustomerEndpointProvider {
  id              String   @id @default(uuid())
  projectKey      String   @map("project_key")
  name            String
  baseUrl         String   @map("base_url")
  // HMAC signing secret. Plaintext in v1; phase-2 hardening = AES at app layer
  // or move to Vault. See docs/customer-managed-endpoints-implementation.md.
  signingSecret   String   @map("signing_secret")
  // Optional rotation secret. When set, customer accepts either secret;
  // FeatBit signs with the primary (signingSecret) only.
  secondarySecret String?  @map("secondary_secret")
  schemaVersion   Int      @default(1) @map("schema_version")
  timeoutMs       Int      @default(15000) @map("timeout_ms")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([projectKey, name])
  @@index([projectKey])
  @@map("customer_endpoint_provider")
}

model UserProjectMemory {
  id                String   @id @default(uuid())
  featbitProjectKey String   @map("featbit_project_key")
  featbitUserId     String   @map("featbit_user_id")
  key               String
  type              String
  content           String
  sourceAgent       String?  @map("source_agent")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@unique([featbitProjectKey, featbitUserId, key])
  @@index([featbitProjectKey, featbitUserId, type])
  @@map("user_project_memory")
}

// Per-project access tokens used by the local Claude Code agent (and any
// other headless caller of /api/experiments/*). Issued from the UI on
// /data/env-settings, plaintext shown ONCE on creation. Server stores only
// the SHA-256 hash. `projectKey` is the scope — a token only authorises
// requests against experiments whose featbitProjectKey matches.
model AgentToken {
  id              String    @id @default(uuid())
  tokenHash       String    @unique @map("token_hash")
  projectKey      String    @map("project_key")
  // First ~12 chars of the plaintext (e.g. "fbat_abc1234"), shown in the UI
  // so users can identify which token a row corresponds to. Not a secret.
  prefix          String
  label           String
  createdByUserId String?   @map("created_by_user_id")
  issuedAt        DateTime  @default(now()) @map("issued_at")
  lastUsedAt      DateTime? @map("last_used_at")
  revokedAt       DateTime? @map("revoked_at")

  @@index([projectKey])
  @@map("agent_token")
}

model AuthSession {
  id              String   @id
  featbitToken    String   @map("featbit_token")
  featbitCookies  Json     @map("featbit_cookies")
  profile         Json
  workspaceId     String?  @map("workspace_id")
  organizationId  String?  @map("organization_id")
  expiresAt       DateTime @map("expires_at")
  refreshedAt     DateTime @default(now()) @map("refreshed_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("auth_session")
}
