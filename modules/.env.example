# Copy to .env and adjust. Defaults work for the full embedded stack
# (postgres + clickhouse spun up by docker-compose.yml). Override the
# DATABASE_URL / CLICKHOUSE_CONNECTION_STRING entries to point at external
# data stores instead.

# ──────────────────────────────────────────────────────────────────────────────
# Image version. Pin to the released tag you want to run.
# ──────────────────────────────────────────────────────────────────────────────
VERSION=0.0.4-beta

# ──────────────────────────────────────────────────────────────────────────────
# Embedded PostgreSQL (used by web). Skip these if DATABASE_URL points
# elsewhere — the `postgres` service won't be started in that case.
# ──────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=featbit
POSTGRES_PASSWORD=featbit_local_pw
POSTGRES_DB=release_decision
# DATABASE_URL takes precedence; uncomment + set to use an external PG.
# DATABASE_URL=postgresql://USER:URL_ENCODED_PASSWORD@HOST:5432/DB?sslmode=require

# ──────────────────────────────────────────────────────────────────────────────
# Embedded ClickHouse (used by track-service). Skip these if
# CLICKHOUSE_CONNECTION_STRING points elsewhere.
# ──────────────────────────────────────────────────────────────────────────────
CLICKHOUSE_USER=featbit
CLICKHOUSE_PASSWORD=featbit_local_pw
CLICKHOUSE_DATABASE=featbit
# CLICKHOUSE_CONNECTION_STRING takes precedence; uncomment to use an external CH.
# CLICKHOUSE_CONNECTION_STRING=Host=HOST;Port=8123;User=USER;Password=PASS;Protocol=http;Database=featbit

# ──────────────────────────────────────────────────────────────────────────────
# Cross-service HMAC for env-secret validation. Generate once for your stack:
#   openssl rand -base64 48
# Both web and track-service must see the SAME value.
# ──────────────────────────────────────────────────────────────────────────────
TRACK_SERVICE_SIGNING_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# FeatBit backend (auth). Defaults to FeatBit SaaS; self-hosters of
# github.com/featbit/featbit point this at their own API. Server-only —
# never reaches the browser (browser goes through web's /api/featbit-proxy).
# ──────────────────────────────────────────────────────────────────────────────
# FEATBIT_API_URL=https://app-api.featbit.co

# ──────────────────────────────────────────────────────────────────────────────
# sandbox0 Managed Agents — required for the chat panel in Managed mode.
# Without SANDBOX0_API_KEY the chat returns 401 on first message.
# ──────────────────────────────────────────────────────────────────────────────
SANDBOX0_API_KEY=
# SANDBOX0_BASE_URL=https://agents.sandbox0.ai
