{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "featbit-analyze",
  "main": "worker/index.ts",
  "compatibility_date": "2026-04-01",
  "containers": [
    {
      "class_name": "AnalyzeContainer",
      "image": "./Dockerfile",
      "instance_type": "basic",
      "max_instances": 2
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "ANALYZE_CONTAINER",
        "class_name": "AnalyzeContainer"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["AnalyzeContainer"]
    }
  ],
  "routes": [
    {
      "pattern": "analyze.featbit.ai",
      "custom_domain": true
    }
  ]
}
