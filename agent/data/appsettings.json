{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "FRD.DataServer": "Debug"
    }
  },
  "AllowedHosts": "*",

  // TSDB provider: "cloudflare" (default) or "local"
  // cloudflare → https://tsdb.featbit.ai  (Cloudflare Workers + R2)
  // local      → http://localhost:5059     (docker-compose tsdb service)
  "TsdbProvider": "cloudflare",
  "TsdbBaseUrl": {
    "cloudflare": "https://tsdb.featbit.ai",
    "local": "http://localhost:5059"
  },
  "ExperimentWorker": {
    "IntervalSeconds": 300,
    "MaxConcurrency": 8,
    "ApiBaseUrl": "http://localhost:3000",
    "PythonPath": "python",
    "PythonScriptPath": "Scripts/analyze-bayesian.py"
  }
}
