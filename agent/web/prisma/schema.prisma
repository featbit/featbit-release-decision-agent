generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  stage       String   @default("intent") // intent | hypothesis | implementing | measuring | deciding | learning
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Feature Flag configuration
  flagKey        String?
  envSecret      String?
  accessToken    String?
  flagServerUrl  String?

  // Sandbox configuration
  sandboxId      String?
  sandboxStatus  String?  @default("idle") // idle | running | completed | error

  // Decision state (mirrors intent.md)
  goal           String?
  intent         String?
  hypothesis     String?
  change         String?
  variants       String?
  primaryMetric  String?
  guardrails     String?
  constraints    String?
  openQuestions   String?
  lastAction     String?
  lastLearning   String?

  experiments Experiment[]
  activities  Activity[]
  messages    Message[]
}

model Experiment {
  id          String   @id @default(uuid())
  projectId   String
  slug        String
  status      String   @default("draft") // draft | running | analyzing | decided | archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Definition
  hypothesis         String?  // copy of project hypothesis at experiment start
  method             String?  // bayesian_ab | bandit
  methodReason       String?  // why this method was chosen
  primaryMetricEvent String?
  metricDescription  String?  // human-readable description of primary metric
  guardrailEvents    String?  // JSON array stored as string
  guardrailDescriptions String? // JSON object {"event_name": "description", ...}
  controlVariant     String?
  treatmentVariant   String?
  trafficAllocation  String?  // how traffic is split: dispatch key, split ratios, staining
  minimumSample      Int?
  observationStart   DateTime?
  observationEnd     DateTime?
  priorProper        Boolean  @default(false)
  priorMean          Float?
  priorStddev        Float?

  // Raw data snapshot
  inputData          String?  // JSON stored as string (mirrors input.json)

  // Analysis results
  analysisResult     String?  // Markdown output from analysis script
  decision           String?  // CONTINUE | PAUSE | ROLLBACK_CANDIDATE | INCONCLUSIVE
  decisionSummary    String?  // Plain-language action recommendation for non-technical readers
  decisionReason     String?  // Technical rationale with data points

  // Learning
  whatChanged         String?
  whatHappened         String?
  confirmedOrRefuted  String?
  whyItHappened       String?
  nextHypothesis      String?

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, slug])
}

model Activity {
  id        String   @id @default(uuid())
  projectId String
  type      String   // stage_change | sandbox_event | decision | note
  title     String
  detail    String?
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Message {
  id        String   @id @default(uuid())
  projectId String
  role      String   // "user" | "assistant" | "system"
  content   String
  metadata  String?  // JSON — stage updates, data changes, tool calls, etc.
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
