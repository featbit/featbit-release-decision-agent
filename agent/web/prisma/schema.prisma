generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model Experiment {
  id            String          @id @default(uuid())
  name          String
  description   String?
  stage         String          @default("hypothesis")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  flagKey       String?         @map("flag_key")
  envSecret     String?         @map("env_secret")
  accessToken   String?         @map("access_token")
  flagServerUrl String?         @map("flag_server_url")
  featbitProjectKey String?     @map("featbit_project_key")
  featbitEnvId      String?     @map("featbit_env_id")
  sandboxId     String?         @map("sandbox_id")
  sandboxStatus String?         @default("idle") @map("sandbox_status")
  goal          String?
  intent        String?
  hypothesis    String?
  change        String?
  variants      String?
  primaryMetric String?         @map("primary_metric")
  guardrails    String?
  constraints   String?
  openQuestions String?         @map("open_questions")
  lastAction    String?         @map("last_action")
  lastLearning  String?         @map("last_learning")
  activities    Activity[]
  experimentRuns ExperimentRun[]
  messages      Message[]

  @@map("experiment")
}

model ExperimentRun {
  id                    String     @id @default(uuid())
  experimentId          String     @map("experiment_id")
  slug                  String
  status                String     @default("draft")
  createdAt             DateTime   @default(now()) @map("created_at")
  updatedAt             DateTime   @updatedAt @map("updated_at")
  hypothesis            String?
  method                String?
  methodReason          String?    @map("method_reason")
  primaryMetricEvent    String?    @map("primary_metric_event")
  metricDescription     String?    @map("metric_description")
  guardrailEvents       String?    @map("guardrail_events")
  guardrailDescriptions String?    @map("guardrail_descriptions")
  controlVariant        String?    @map("control_variant")
  treatmentVariant      String?    @map("treatment_variant")
  trafficAllocation     String?    @map("traffic_allocation")
  minimumSample         Int?       @map("minimum_sample")
  observationStart      DateTime?  @map("observation_start")
  observationEnd        DateTime?  @map("observation_end")
  priorProper           Boolean    @default(false) @map("prior_proper")
  priorMean             Float?     @map("prior_mean")
  priorStddev           Float?     @map("prior_stddev")
  inputData             String?    @map("input_data")
  analysisResult        String?    @map("analysis_result")
  decision              String?
  decisionSummary       String?    @map("decision_summary")
  decisionReason        String?    @map("decision_reason")
  whatChanged           String?    @map("what_changed")
  whatHappened          String?    @map("what_happened")
  confirmedOrRefuted    String?    @map("confirmed_or_refuted")
  whyItHappened         String?    @map("why_it_happened")
  nextHypothesis        String?    @map("next_hypothesis")
  runId                 String?    @map("run_id")
  primaryMetricAgg      String?    @default("once") @map("primary_metric_agg")
  primaryMetricType     String?    @default("binary") @map("primary_metric_type")
  trafficPercent        Float?     @default(100) @map("traffic_percent")
  layerId               String?    @map("layer_id")
  audienceFilters       String?    @map("audience_filters")
  trafficOffset         Int?       @default(0) @map("traffic_offset")
  experiment            Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@unique([experimentId, slug])
  @@map("experiment_run")
}

model Activity {
  id           String     @id @default(uuid())
  experimentId String     @map("experiment_id")
  type         String
  title        String
  detail       String?
  createdAt    DateTime   @default(now()) @map("created_at")
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@map("activity")
}

model Message {
  id           String     @id @default(uuid())
  experimentId String     @map("experiment_id")
  role         String
  content      String
  metadata     String?
  createdAt    DateTime   @default(now()) @map("created_at")
  experiment   Experiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@map("message")
}

/// This table is a partition table and requires additional setup for migrations. Visit https://pris.ly/d/partition-tables for more info.
model flag_evaluations {
  id            BigInt   @default(autoincrement())
  env_id        String
  flag_key      String
  user_key      String
  variant       String
  experiment_id String?
  layer_id      String?
  evaluated_at  DateTime @db.Timestamptz(6)
  received_at   DateTime @default(now()) @db.Timestamptz(6)
  session_id    String?
  user_props    Json     @default("{}")

  @@id([id, evaluated_at])
  @@index([env_id, flag_key, evaluated_at], map: "idx_fe_env_flag_time")
  @@index([env_id, flag_key, variant, evaluated_at], map: "idx_fe_env_flag_variant")
  @@index([env_id, user_key, evaluated_at], map: "idx_fe_env_user")
  @@index([experiment_id, evaluated_at], map: "idx_fe_experiment", where: raw("(experiment_id IS NOT NULL)"))
  @@index([user_props(ops: JsonbPathOps)], map: "idx_fe_user_props", type: Gin)
}

/// This table is a partition table and requires additional setup for migrations. Visit https://pris.ly/d/partition-tables for more info.
model metric_events {
  id            BigInt   @default(autoincrement())
  env_id        String
  event_name    String
  event_id      String?
  insert_id     String?
  user_key      String
  anonymous_id  String?
  account_id    String?
  numeric_value Decimal? @db.Decimal
  occurred_at   DateTime @db.Timestamptz(6)
  received_at   DateTime @default(now()) @db.Timestamptz(6)
  session_id    String?
  source        String?
  platform      String?
  page_url      String?
  screen_name   String?
  referrer      String?
  app_version   String?
  country       String?
  region        String?
  city          String?
  device_type   String?
  os_name       String?
  browser_name  String?
  unit          String?
  currency      String?
  props         Json     @default("{}")

  @@id([id, occurred_at])
  @@index([env_id, account_id, occurred_at], map: "idx_me_env_account", where: raw("(account_id IS NOT NULL)"))
  @@index([env_id, anonymous_id, occurred_at], map: "idx_me_env_anon", where: raw("(anonymous_id IS NOT NULL)"))
  @@index([env_id, event_name, occurred_at], map: "idx_me_env_event_time")
  @@index([env_id, occurred_at], map: "idx_me_env_time")
  @@index([env_id, user_key, occurred_at], map: "idx_me_env_user")
  @@index([event_name, occurred_at], map: "idx_me_event_time")
  @@index([env_id, insert_id, occurred_at], map: "idx_me_insert_id", where: raw("(insert_id IS NOT NULL)"))
  @@index([props(ops: JsonbPathOps)], map: "idx_me_props", type: Gin)
  @@index([session_id, occurred_at], map: "idx_me_session_time", where: raw("(session_id IS NOT NULL)"))
}
