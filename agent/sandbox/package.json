{
  "name": "claude-agent-server",
  "version": "1.0.0",
  "description": "TypeScript SSE server bridging external clients with the Claude Agent SDK",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.92",
    "cors": "2.8.6",
    "dotenv": "17.4.1",
    "express": "5.2.1"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.5.2",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
