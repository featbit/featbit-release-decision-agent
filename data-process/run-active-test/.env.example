# PostgreSQL — same as agent/web/.env and stats-service/.env
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# cf-worker endpoint that accepts /api/track
WORKER_URL=http://localhost:8787

# Event generation tick (seconds)
TICK_SECONDS=5

# Max events per tick (each tick generates a random number in [0, MAX])
MAX_EVENTS_PER_TICK=10
