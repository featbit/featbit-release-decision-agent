{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "featbit-data-process",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-01",
  "account_id": "1f45ccf79bea72356d22bfa7ccec6e32",

  "r2_buckets": [
    {
      "binding": "TSDB_BUCKET",
      "bucket_name": "featbit-tsdb"
    }
  ],

  "durable_objects": {
    "bindings": [
      {
        "name": "PARTITION_WRITER",
        "class_name": "PartitionWriterDO"
      }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["PartitionWriterDO"]
    }
  ],
  "routes": [
    {
      "pattern": "data-process.featbit.ai",
      "custom_domain": true
    }
  ]
}
